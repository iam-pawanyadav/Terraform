# Terraform .gitignore
# Reference: https://github.com/github/gitignore/blob/main/Terraform.gitignore

# -----------------------------------------------------------------------
# LOCAL TERRAFORM DIRECTORY
# Created by terraform init — never commit, always regenerable
# -----------------------------------------------------------------------
.terraform/
.terraform.lock.hcl   # Optional: some teams commit this for reproducibility

# -----------------------------------------------------------------------
# STATE FILES
# May contain plaintext secrets (passwords, private keys, access tokens)
# Use remote backend (S3) instead and NEVER commit these
# -----------------------------------------------------------------------
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# -----------------------------------------------------------------------
# VARIABLE FILES
# terraform.tfvars and *.tfvars often contain sensitive values
# Commit example files (e.g. terraform.tfvars.example) but not real values
# -----------------------------------------------------------------------
terraform.tfvars
*.tfvars

# -----------------------------------------------------------------------
# PLAN FILES
# Binary files produced by terraform plan -out=...
# -----------------------------------------------------------------------
*.tfplan

# -----------------------------------------------------------------------
# CRASH LOGS
# -----------------------------------------------------------------------
crash.log
crash.*.log

# -----------------------------------------------------------------------
# OVERRIDE FILES
# Used for local overrides — not for sharing
# -----------------------------------------------------------------------
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------------------------------------------------------------
# SSH KEYS & CREDENTIALS
# Never commit .pem files or credential files
# -----------------------------------------------------------------------
*.pem
*.key
credentials

# -----------------------------------------------------------------------
# LOCAL NOTES & IDE FILES
# -----------------------------------------------------------------------
.idea/
.vscode/
*.swp
.DS_Store
